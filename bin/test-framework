#!/usr/bin/env bash
# Run the full test suite for the offline-lab-framework.
# Usage: bin/test-framework [--lint] [--filter <pattern>]
#
#   --lint              Run shellcheck and shfmt checks before tests
#   --filter <pattern>  Run only tests matching a pattern (passed to bats --filter)

set -euo pipefail

# Resolve paths relative to this script, regardless of working directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
FRAMEWORK_DIR="${SCRIPT_DIR}/../framework"
LIBRARY_PATH="${FRAMEWORK_DIR}/library"
TEST_DIR="${FRAMEWORK_DIR}/tests/unit"

run_lint=0
filter_pattern=""

while [[ "${#}" -gt 0 ]]; do
    case "${1}" in
        --lint)
            run_lint=1
            shift
            ;;
        --filter)
            filter_pattern="${2}"
            shift 2
            ;;
        -h | --help)
            printf 'Usage: bin/test-framework [--lint] [--filter <pattern>]\n'
            exit 0
            ;;
        *)
            printf 'Unknown option: %s\n' "${1}" >&2
            exit 1
            ;;
    esac
done

fail=0

if [[ "${run_lint}" -eq 1 ]]; then
    printf '==> shellcheck\n'
    shellcheck -s bash "${LIBRARY_PATH}"/*.sh "${FRAMEWORK_DIR}"/bin/labctl* \
        "${FRAMEWORK_DIR}/bin/chronic" "${FRAMEWORK_DIR}/bin/framework" \
        "${FRAMEWORK_DIR}/bin/dev-setup" || fail=1

    printf '==> shfmt\n'
    shfmt -d -i 4 -ci "${LIBRARY_PATH}"/*.sh "${FRAMEWORK_DIR}"/bin/labctl* \
        "${FRAMEWORK_DIR}/bin/chronic" "${FRAMEWORK_DIR}/bin/framework" || fail=1

    if [[ "${fail}" -ne 0 ]]; then
        printf '\nLint failed.\n' >&2
        exit 1
    fi

    printf 'Lint OK\n\n'
fi

printf '==> bats\n'

bats_args=()
[[ -n "${filter_pattern}" ]] && bats_args+=(--filter "${filter_pattern}")
bats_args+=("${TEST_DIR}")

FRAMEWORK_LIB_PATH="${LIBRARY_PATH}" bats "${bats_args[@]}"
