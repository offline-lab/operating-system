# vi: ft=bash
# shellcheck shell=bash

# Usage:
#   bin/test-qemu [--build] [pytest-args...]
#
# Boots a QEMU arm64 image and runs the integration test suite against it.
# QEMU is managed here; pytest connects via --host.
#
# Options:
#   --build        Build and fetch the qemu-arm64 image via buildbox first.
#
# Prerequisites:
#   - qemu-system-aarch64 installed (brew install qemu)
#   - .ssh/builder holds the SSH private key for testuser
#   - .config has BR2_PACKAGE_OFFLINELAB_TESTING_TESTUSER_PUBKEY set
#   - uv installed (brew install uv) and tests/.venv populated (cd tests && uv sync)
#   - artifacts/qemu-arm64/ populated (or pass --build)

set -eu -o pipefail

REPO_ROOT="$(cd "$(dirname "${0}")/.." && pwd)"
ARTIFACTS="${REPO_ROOT}/artifacts/qemu-arm64"
SSH_KEY="${REPO_ROOT}/.ssh/builder"
SSH_PORT=2223
TEST_DIR=""
QEMU_PID=""

BUILD=0
EXTRA_ARGS=()

for arg in "$@"; do
    case "${arg}" in
    --build) BUILD=1 ;;
    *) EXTRA_ARGS+=("${arg}") ;;
    esac
done

function cleanup() {
    local exit_code="${?}"
    if [[ -n "${QEMU_PID}" ]]; then
        kill "${QEMU_PID}" 2>/dev/null || true
        wait "${QEMU_PID}" 2>/dev/null || true
    fi
    if [[ -n "${TEST_DIR}" ]]; then
        if [[ "${exit_code}" -ne 0 ]]; then
            printf 'Serial log preserved at: %s\n' "${SERIAL_LOG}" >&2
        else
            rm -rf "${TEST_DIR}"
        fi
    fi
}

trap cleanup EXIT

function _ssh() {
    SSH_AUTH_SOCK=/dev/null ssh \
        -i "${SSH_KEY}" \
        -o IdentitiesOnly=yes \
        -o IdentityAgent=none \
        -o StrictHostKeyChecking=no \
        -o UserKnownHostsFile=/dev/null \
        -o BatchMode=yes \
        -o ConnectTimeout=5 \
        -p "${SSH_PORT}" \
        testuser@127.0.0.1 "$@" 2>/dev/null
}

function wait_for_ssh() {
    local attempt=0

    printf 'Waiting for SSH on port %d...\n' "${SSH_PORT}"

    while [[ ${attempt} -lt 60 ]]; do
        if _ssh true; then
            printf 'SSH ready.\n'
            return 0
        fi
        attempt=$((attempt + 1))
        sleep 5
    done

    printf 'ERROR: SSH not available on port %d after 300s\n' "${SSH_PORT}" >&2
    printf 'Serial log: %s\n' "${SERIAL_LOG}" >&2
    return 1
}

function wait_for_system() {
    local attempt=0

    printf 'Waiting for systemd to reach stable state...\n'

    while [[ ${attempt} -lt 30 ]]; do
        local state
        state="$(_ssh 'systemctl is-system-running' || true)"
        if [[ "${state}" == "running" || "${state}" == "degraded" ]]; then
            printf 'System state: %s\n' "${state}"
            return 0
        fi
        attempt=$((attempt + 1))
        sleep 5
    done

    printf 'ERROR: system did not reach stable state after 150s\n' >&2
    printf 'Serial log: %s\n' "${SERIAL_LOG}" >&2
    return 1
}

if [[ "${BUILD}" -eq 1 ]]; then
    printf 'Building qemu-arm64 image on buildbox...\n'

    "${REPO_ROOT}/bin/buildbox.sh" build qemu-arm64
    "${REPO_ROOT}/bin/buildbox.sh" fetch qemu-arm64
fi

if [[ ! -f "${ARTIFACTS}/u-boot.bin" ]]; then
    printf 'ERROR: artifacts not found at %s\n' "${ARTIFACTS}" >&2
    printf 'Run: bin/test-qemu --build\n' >&2

    exit 1
fi

if [[ ! -f "${SSH_KEY}" ]]; then
    printf 'ERROR: SSH key not found at %s\n' "${SSH_KEY}" >&2
    printf 'Expected: .ssh/builder\n' >&2

    exit 1
fi

TEST_DIR="$(mktemp -d)"
SERIAL_LOG="${TEST_DIR}/serial.log"

printf 'Copying disk image...\n'
cp "${ARTIFACTS}/offlinelab-qemu-arm64.img" "${TEST_DIR}/disk.img"

printf 'Starting QEMU (serial log: %s)...\n' "${SERIAL_LOG}"
qemu-system-aarch64 \
    -machine virt \
    -cpu cortex-a53 \
    -m 512M \
    -smp 4 \
    -bios "${ARTIFACTS}/u-boot.bin" \
    -drive "file=${TEST_DIR}/disk.img,format=raw,if=virtio,id=hd0" \
    -netdev "user,id=net0,hostfwd=tcp::${SSH_PORT}-:22" \
    -device "virtio-net-pci,netdev=net0" \
    -nographic \
    </dev/null >"${SERIAL_LOG}" 2>&1 &
QEMU_PID="$!"

wait_for_ssh
wait_for_system

export OL_SSH_KEY="${SSH_KEY}"

cd "${REPO_ROOT}/tests"
bin/run-tests \
    --host "ssh://testuser@localhost:${SSH_PORT}" \
    "${EXTRA_ARGS[@]}"
