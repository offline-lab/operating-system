# Offline Lab OS — common kernel requirements
# Applied to every board on top of its upstream defconfig.
# Keep this to OS-required options only; hardware goes in boards/<family>/fragments/linux-hardware.config.

# Version tag — appended to uname -r (e.g. 6.12.35-v8+-offlinelab)
CONFIG_LOCALVERSION="-offlinelab"
CONFIG_LOCALVERSION_AUTO=n

# AppArmor — mandatory LSM for all OS security policy
CONFIG_SECURITY=y
CONFIG_SECURITY_NETWORK=y
CONFIG_SECURITY_PATH=y
CONFIG_SECURITY_APPARMOR=y
CONFIG_DEFAULT_SECURITY_APPARMOR=y
CONFIG_SECURITY_APPARMOR_HASH=y
CONFIG_SECURITY_APPARMOR_HASH_DEFAULT=y
CONFIG_SECURITY_APPARMOR_EXPORT_BINARY=y
CONFIG_SECURITY_APPARMOR_INTROSPECT_POLICY=y
CONFIG_SECURITY_APPARMOR_PARANOID_LOAD=y
CONFIG_LSM="apparmor"
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y

# systemd requirements
CONFIG_CGROUPS=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_MEMCG=y
CONFIG_BLK_CGROUP=y
CONFIG_CPUSETS=y
CONFIG_SCHED_AUTOGROUP=y
CONFIG_NAMESPACES=y
CONFIG_UTS_NS=y
CONFIG_IPC_NS=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y
CONFIG_USER_NS=y
CONFIG_SYSVIPC=y
CONFIG_POSIX_MQUEUE=y
CONFIG_HIGH_RES_TIMERS=y
CONFIG_INOTIFY_USER=y
CONFIG_FANOTIFY=y
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_BINFMT_MISC=y

# Overlay filesystem — A/B rootfs, sysext, confext
CONFIG_OVERLAY_FS=y
CONFIG_OVERLAY_FS_REDIRECT_DIR=y
CONFIG_OVERLAY_FS_INDEX=y

# Filesystems
CONFIG_EXT4_FS=y
CONFIG_SQUASHFS=y
CONFIG_SQUASHFS_LZO=y
CONFIG_VFAT_FS=y
CONFIG_MSDOS_FS=y
CONFIG_MSDOS_PARTITION=y

# Initramfs — required for our init to unpack and switch_root
CONFIG_BLK_DEV_INITRD=y
CONFIG_RD_GZIP=y

# Expose running kernel config (useful for debugging on any board)
CONFIG_IKCONFIG=y
CONFIG_IKCONFIG_PROC=y

# RAUC A/B OTA — device mapper + dm-verity bundles
CONFIG_MD=y
CONFIG_BLK_DEV_DM=y
CONFIG_DM_VERITY=y
CONFIG_DM_VERITY_VERIFY_ROOTHASH_SIG=y
CONFIG_DM_BUFIO=y
CONFIG_BLK_DEV_LOOP=y

# devtmpfs — required by initramfs init
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# zram swap — all backends must match init-zram-swap (lz4 by default)
CONFIG_ZRAM=m
CONFIG_ZRAM_BACKEND_LZ4=y
CONFIG_ZRAM_BACKEND_LZO=y
CONFIG_ZRAM_BACKEND_ZSTD=y
CONFIG_ZRAM_DEF_COMP_LZ4=y
CONFIG_ZRAM_DEF_COMP="lz4"

# USB gadget — ACM serial + ECM network composite
CONFIG_CONFIGFS_FS=y
CONFIG_USB_GADGET=y
CONFIG_USB_CONFIGFS=y
CONFIG_USB_CONFIGFS_SERIAL=y
CONFIG_USB_CONFIGFS_ACM=y
CONFIG_USB_CONFIGFS_ECM=y
CONFIG_USB_F_ACM=y
CONFIG_USB_F_ECM=y
CONFIG_USB_F_SERIAL=y
CONFIG_USB_LIBCOMPOSITE=y
CONFIG_USB_U_ETHER=y
CONFIG_USB_U_SERIAL=y

# Crypto — RAUC bundle signing/verification + zram compression
CONFIG_CRYPTO=y
CONFIG_CRYPTO_SHA256=y
CONFIG_CRYPTO_AES=y
CONFIG_CRYPTO_LZ4=y
CONFIG_CRYPTO_LZO=y
CONFIG_CRYPTO_ZSTD=y
CONFIG_LZ4_COMPRESS=y
CONFIG_ZSTD_COMPRESS=y

# Networking fundamentals
CONFIG_IPV6=y
CONFIG_IP_ADVANCED_ROUTER=y
CONFIG_WIRELESS=y
CONFIG_CFG80211=m

# Netfilter — nftables packet filtering (IPv4 + IPv6 via inet family)
# All built-in: embedded image has no module autoload.
CONFIG_NETFILTER=y
CONFIG_NETFILTER_ADVANCED=y
CONFIG_NF_CONNTRACK=y
CONFIG_NF_DEFRAG_IPV4=y
CONFIG_NF_DEFRAG_IPV6=y
CONFIG_NF_REJECT_IPV4=y
CONFIG_NF_REJECT_IPV6=y
CONFIG_NF_TABLES=y
CONFIG_NF_TABLES_IPV4=y
CONFIG_NF_TABLES_IPV6=y
CONFIG_NF_TABLES_INET=y
CONFIG_NFT_CT=y
CONFIG_NFT_META=y
CONFIG_NFT_REJECT=y
CONFIG_NFT_REJECT_IPV4=y
CONFIG_NFT_REJECT_IPV6=y
