image bootfs.vfat {
    size = 32M
    vfat {
        label = "bootfs"
        files = {
#BOOT_FILES#
        }
    }
}

image #IMAGE_NAME# {
    hdimage {
        partition-table-type = "gpt"
        align = 1M
    }

    partition boot {
        partition-type-uuid = "esp"
        image = "bootfs.vfat"
    }

    partition kernel-a {
        partition-type-uuid = "linux-generic"
        size = 24M
        image = "kernel-a.img"
    }

    partition rootfs-a {
        partition-type-uuid = "linux-generic"
        image = "rootfs.squashfs"
    }

    partition kernel-b {
        partition-type-uuid = "linux-generic"
        size = 24M
    }

    partition rootfs-b {
        partition-type-uuid = "linux-generic"
        size = 512M
    }

    partition bootstate {
        partition-type-uuid = "linux-generic"
        size = 8M
    }

    partition overlay {
        partition-type-uuid = "linux-generic"
        image = "overlay.ext4"
    }

    partition data {
        partition-type-uuid = "linux-generic"
        image = "data.ext4"
    }
}
