# Serial UARTs
CONFIG_SERIAL_8250_RUNTIME_UARTS=5

# OverlayFS
CONFIG_OVERLAY_FS=y
CONFIG_OVERLAY_FS_REDIRECT_DIR=y
CONFIG_OVERLAY_FS_INDEX=y

# Initramfs
CONFIG_BLK_DEV_INITRD=y
CONFIG_RD_GZIP=y

# USB OTG (dwc2: host mode for keyboards, gadget mode for ACM+ECM+mass storage)
CONFIG_USB_DWC2=y
CONFIG_USB_DWC2_DUAL_ROLE=y
CONFIG_USB_GADGET=y
CONFIG_USB_HID=y
CONFIG_HID_GENERIC=y
CONFIG_USB_CONFIGFS=y
CONFIG_USB_LIBCOMPOSITE=y
CONFIG_USB_CONFIGFS_ACM=y
CONFIG_USB_CONFIGFS_ECM=y
CONFIG_USB_CONFIGFS_SERIAL=y
CONFIG_USB_CONFIGFS_MASS_STORAGE=y
CONFIG_USB_F_ACM=y
CONFIG_USB_F_ECM=y
CONFIG_USB_F_SERIAL=y
CONFIG_USB_U_SERIAL=y
CONFIG_USB_U_ETHER=y
CONFIG_CONFIGFS_FS=y

# Expose running kernel config via /proc/config.gz
CONFIG_IKCONFIG=y
CONFIG_IKCONFIG_PROC=y

# zram compressed swap
CONFIG_ZRAM=m
CONFIG_CRYPTO_LZ4=y
CONFIG_LZ4_COMPRESS=y
CONFIG_LZ4_DECOMPRESS=y

# ============================================================
# Phase 0.5 — Disable unused drivers/subsystems
# ============================================================
# Baseline: bcm2711_defconfig (rpi-6.12.y, ~3800 enabled options)
# Target: ~2000 options for Pi Zero 2W
#
# Modules confirmed needed at runtime (lsmod on hardware):
#   WiFi:  brcmfmac, cfg80211
#   BT:    bluetooth, hci_uart, btbcm
#   GPU:   vc4, drm_kms_helper, drm, cec
#   Audio: snd_bcm2835, snd_soc_core, snd_soc_hdmi_codec
#   Video: bcm2835_codec/v4l2/isp (VCHIQ pipeline)
#   Misc:  zram, fuse, i2c_bcm2835, ipv6, sch_fq_codel

