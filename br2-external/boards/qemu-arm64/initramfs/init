mount -t proc proc /proc
mount -t sysfs sysfs /sys
mount -t devtmpfs devtmpfs /dev

echo "offlinelab: initramfs starting (qemu-arm64)"

echo /bin/mdev > /proc/sys/kernel/hotplug
mdev -s

# Parse slot from kernel cmdline (default: A)
SLOT="a"
for arg in $(cat /proc/cmdline); do
    case "${arg}" in
        rauc.slot=A) SLOT="a" ;;
        rauc.slot=B) SLOT="b" ;;
    esac
done

# Partition mapping for virtio block (/dev/vda):
#   p1=boot(FAT) p2=extended p3=overlay p4=data
#   p5=kernel-a p6=rootfs-a p7=kernel-b p8=rootfs-b p9=bootstate
case "${SLOT}" in
    a) ROOTFS_DEV="/dev/vda6" ;;
    b) ROOTFS_DEV="/dev/vda8" ;;
esac
OVERLAY_DEV="/dev/vda3"
DATA_DEV="/dev/vda4"

echo "offlinelab: slot=${SLOT} rootfs=${ROOTFS_DEV}"

i=0
while [ ! -b "${ROOTFS_DEV}" ] && [ "$i" -lt 50 ]; do
    i=$((i + 1))
    sleep 0.1
done

if [ ! -b "${ROOTFS_DEV}" ]; then
    echo "offlinelab: FATAL - ${ROOTFS_DEV} not found"
    cat /proc/partitions
    exec sh
fi

mount -t ext4 -o ro,noatime "${ROOTFS_DEV}" /mnt

mount -t ext4 -o rw,noatime "${OVERLAY_DEV}" /overlay
mkdir -p "/overlay/${SLOT}/upper" "/overlay/${SLOT}/work"

mount -t overlay overlay \
    -o "lowerdir=/mnt,upperdir=/overlay/${SLOT}/upper,workdir=/overlay/${SLOT}/work" \
    /newroot

mkdir -p /newroot/mnt/overlay
mount --move /overlay /newroot/mnt/overlay

mount -t ext4 -o rw,noatime "${DATA_DEV}" /data
mkdir -p /newroot/data
mount --bind /data /newroot/data

mkdir -p /newroot/proc /newroot/sys /newroot/dev
mount --move /proc /newroot/proc
mount --move /sys /newroot/sys
mount --move /dev /newroot/dev

echo "offlinelab: switching to rootfs (slot ${SLOT})"
exec switch_root /newroot /sbin/init
