# Override distro_bootcmd to directly load our boot.scr from virtio disk p1.
# ${loadaddr} is always defined in U-Boot arm64; boot.scr is tiny so overlap
# with the kernel load address is not a concern before source executes.
CONFIG_BOOTCOMMAND="load virtio 0:1 ${loadaddr} boot.scr; source ${loadaddr}"

# Squashfs read support (kernel-a.img is squashfs)
CONFIG_FS_SQUASHFS=y
CONFIG_LZO=y
# Disable video/splash — no display in -nographic QEMU; missing logo symbol
# causes linker error when CONFIG_VIDEO_BMP_LOGO is set by qemu_arm64 defconfig
# CONFIG_VIDEO_LOGO is not set
# CONFIG_VIDEO_BMP_LOGO is not set
# CONFIG_SPLASH_SCREEN is not set
# CONFIG_VIDEO is not set
