# Raspberry Pi family — hardware fragment
# Applied on top of bcm2711_defconfig + boards/common/fragments/linux-kernel.config.
# Only options that change behavior vs bcm2711_defconfig defaults.

# Power management — needed for battery/embedded use
CONFIG_SUSPEND=y
CONFIG_PM_SLEEP=y
CONFIG_ARM_PSCI_CPUIDLE=y

# CPU frequency — schedutil is more responsive than ondemand on Pi
CONFIG_CPU_FREQ_DEFAULT_GOV_SCHEDUTIL=y
# CONFIG_CPU_FREQ_DEFAULT_GOV_ONDEMAND is not set

# cpufreq governors for power profile switching (offlinelab-power-profiles)
CONFIG_CPU_THERMAL=y
CONFIG_CPU_FREQ_GOV_PERFORMANCE=y
CONFIG_CPU_FREQ_GOV_POWERSAVE=y
CONFIG_CPU_FREQ_GOV_SCHEDUTIL=y

# Timer — 100Hz reduces idle wakeups; sufficient for embedded workloads
CONFIG_HZ_100=y
CONFIG_HZ=100
# CONFIG_HZ_250 is not set
CONFIG_NO_HZ_FULL=y
# CONFIG_NO_HZ_IDLE is not set

# Serial — Pi hardware has multiple UART ports
CONFIG_SERIAL_8250_RUNTIME_UARTS=5

# USB OTG — DWC2 controller on BCM2835/2710 (Pi Zero 2W, Pi 3)
CONFIG_USB_DWC2=y
CONFIG_USB_DWC2_DUAL_ROLE=y
CONFIG_USB_HID=y
CONFIG_HID_GENERIC=y
CONFIG_USB_CONFIGFS_MASS_STORAGE=y
CONFIG_USB_F_MASS_STORAGE=y
