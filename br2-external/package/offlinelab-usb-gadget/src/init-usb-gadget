# vi: ft=bash
# shellcheck shell=bash disable=SC1091,SC2312
set -euo pipefail

source framework || exit 1

function usb_gadget::main() {
    log::trace "${FUNCNAME[0]}: configuring USB composite gadget"

    # If the DWC2 is already in host mode (USB device connected), do not switch
    # to gadget mode — writing to UDC while the host controller is active causes
    # dwc2_hc_halt() failures that kill both the USB device and the WiFi IRQ path.
    #
    # Read the mode from the DWC2 sysfs node directly rather than checking for
    # enumerated devices: the product sysfs file only appears after full
    # enumeration, which loses the race against sysinit on faster kernels.
    local dwc2_mode
    dwc2_mode="$(cat /sys/bus/platform/devices/3f980000.usb/mode 2>/dev/null || true)"
    if [[ "${dwc2_mode}" == "host" ]]; then
        exit::ok "${FUNCNAME[0]}: DWC2 is in host mode — USB device connected, skipping gadget setup"
    fi

    local udc
    udc="$(ls /sys/class/udc 2>/dev/null || true)"
    if var::is_empty "${udc}"; then
        exit::ok "${FUNCNAME[0]}: no UDC available, skipping"
    fi

    cd /sys/kernel/config/usb_gadget/
    mkdir -p offlinelab
    cd offlinelab

    echo 0x1d6b >idVendor  # Linux Foundation
    echo 0x0104 >idProduct # Multifunction Composite Gadget
    echo 0x0100 >bcdDevice # v1.0.0
    echo 0x0200 >bcdUSB    # USB2

    echo 0xEF >bDeviceClass
    echo 0x02 >bDeviceSubClass
    echo 0x01 >bDeviceProtocol

    mkdir -p strings/0x409
    echo "offlinelab0001"         >strings/0x409/serialnumber
    echo "Offline Lab"            >strings/0x409/manufacturer
    echo "Offline Lab USB Device" >strings/0x409/product

    mkdir -p configs/c.1/strings/0x409
    echo "ACM+ECM" >configs/c.1/strings/0x409/configuration
    echo 250       >configs/c.1/MaxPower
    echo 0x80      >configs/c.1/bmAttributes

    # ACM serial (ttyGS0)
    mkdir -p functions/acm.usb0
    ln -sf functions/acm.usb0 configs/c.1/

    # ECM ethernet (usb0)
    mkdir -p functions/ecm.usb0
    echo "00:dc:c8:f7:75:15" >functions/ecm.usb0/host_addr
    echo "00:dd:dc:eb:6d:a1" >functions/ecm.usb0/dev_addr
    ln -sf functions/ecm.usb0 configs/c.1/

    udevadm settle -t 5 || :

    echo "${udc}" >UDC

    sleep 2
    systemctl restart systemd-networkd
}

usb_gadget::main "${@}"
