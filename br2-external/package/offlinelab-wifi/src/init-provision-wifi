# vi: ft=bash
# shellcheck shell=bash disable=SC1091,SC2312
set -euo pipefail

source framework || exit 1

readonly BOOT_CONFIG_DIR="/boot/firmware/config"
readonly DATA_CONFIG="/data/config/wifi/wpa_supplicant.conf"

function provision_wifi::main() {
    log::trace "${FUNCNAME[0]}: provisioning WiFi config"

    fs::ensure_dir "${DATA_CONFIG}"

    if fs::is_file "${DATA_CONFIG}"; then
        log::info "${FUNCNAME[0]}: config already exists at ${DATA_CONFIG}"
        return 0
    fi

    # Collect multi-slot credential files sorted alphabetically.
    # Filename order determines wpa_supplicant priority preference.
    local -a credential_files
    mapfile -t credential_files < <(
        find "${BOOT_CONFIG_DIR}" -maxdepth 1 -name 'wpa_supplicant-*.conf' | sort
    )

    # Fall back to legacy single-file for backward compatibility.
    if [[ "${#credential_files[@]}" -eq 0 ]]; then
        local legacy="${BOOT_CONFIG_DIR}/wpa_supplicant.conf"
        if ! fs::is_file "${legacy}"; then
            log::info "${FUNCNAME[0]}: no config found at ${BOOT_CONFIG_DIR}, skipping"
            return 0
        fi
        cp "${legacy}" "${DATA_CONFIG}"
        chmod 600 "${DATA_CONFIG}"
        log::info "${FUNCNAME[0]}: provisioned from ${legacy}"
        return 0
    fi

    # Merge: global header from first file, then all network={} blocks from all files
    # in sorted order. Users control priority via the priority= field within each block.
    local f
    {
        awk '/^network=\{/{exit} {print}' "${credential_files[0]}"
        for f in "${credential_files[@]}"; do
            awk '/^network=\{/,/^\}$/' "${f}"
        done
    } > "${DATA_CONFIG}"

    chmod 600 "${DATA_CONFIG}"
    log::info "${FUNCNAME[0]}: provisioned from ${#credential_files[@]} credential file(s)"
}

provision_wifi::main "${@}"
