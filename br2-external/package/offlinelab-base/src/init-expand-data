# vi: ft=bash
# shellcheck shell=bash disable=SC1091,SC2312
set -euo pipefail

source framework || exit 1

readonly DISK="/dev/mmcblk0"
readonly PART_NUM=4
readonly PART="${DISK}p${PART_NUM}"

function expand_data::main() {
    log::trace "${FUNCNAME[0]}: expanding data partition if needed"

    depends::check_list sfdisk partprobe resize2fs

    if ! fs::is_blockdev "${PART}"; then
        log::warn "${FUNCNAME[0]}: partition ${PART} not found, skipping"
        return 0
    fi

    # Ensure data directories exist — idempotent, runs every boot
    mkdir -p /data/home/admin/.ssh /data/apps /data/extensions /data/confexts /data/config

    if ! fs::is_file /data/home/admin/.bashrc; then
        printf '[ -f /etc/bash.bashrc ] && . /etc/bash.bashrc\n' > /data/home/admin/.bashrc
    fi

    chown -R 1000:1000 /data/home/admin
    chmod 750 /data/home/admin
    chmod 700 /data/home/admin/.ssh

    local current_end disk_end margin
    current_end="$(sfdisk -l "${DISK}" 2>/dev/null | awk -v p="${PART}" '$1 == p {print $3}')"
    disk_end="$(sfdisk -l "${DISK}" 2>/dev/null | awk '/^Disk.*sectors/ {print $7}')"

    exit::if_empty "${current_end}" "${FUNCNAME[0]}: could not determine current end of ${PART}"
    exit::if_empty "${disk_end}" "${FUNCNAME[0]}: could not determine disk size of ${DISK}"

    margin=$(( disk_end - current_end ))
    if [[ "${margin}" -lt 2048 ]]; then
        log::info "${FUNCNAME[0]}: partition already at full size"
        return 0
    fi

    log::info "${FUNCNAME[0]}: expanding partition ${PART_NUM} on ${DISK} (margin: ${margin} sectors)"
    echo ",+" | sfdisk -N "${PART_NUM}" "${DISK}" --no-reread \
        || exit::error "${FUNCNAME[0]}: sfdisk failed to resize partition"
    partprobe "${DISK}" || log::warn "${FUNCNAME[0]}: partprobe returned non-zero (may be harmless)"
    sleep 1
    resize2fs "${PART}" || exit::error "${FUNCNAME[0]}: resize2fs failed on ${PART}"

    log::info "${FUNCNAME[0]}: done"
}

expand_data::main "${@}"
