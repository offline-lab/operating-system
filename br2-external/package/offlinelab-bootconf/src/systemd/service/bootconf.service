[Unit]
Description=Bootconf — boot-time configuration
Documentation=https://github.com/offline-lab/bootconf
After=local-fs.target boot-firmware.mount
Wants=boot-firmware.mount
ConditionPathExists=/boot/firmware/bootconf.yaml
Before=expand-data.service network.target

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/usr/local/bin/bootconf run --config /boot/firmware/bootconf.yaml
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
