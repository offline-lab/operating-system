[Unit]
Description=Apply bootconf-generated user accounts
Documentation=https://github.com/offline-lab/bootconf
After=bootconf.service
Wants=bootconf.service
ConditionPathIsDirectory=/data/config/users

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=systemd-sysusers /data/config/users/
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
