#
# Bootconf configuration — rename this file to bootconf.yaml to activate.
# Runs every boot. Each section is independently enabled/disabled.
# See: https://github.com/offline-lab/bootconf
#

#
# Bootconf configuration: manipulate how the tool itself works.
#
bootconf:
  enabled: true
  directory: /data/config/bootconf

#
# Wifi configuration
#
wifi:
  enabled: true
  country: NL
  directory: /data/config/wifi
  password_hash: 'a2b3c4d5e6f7a2b3c4d5e6f7a2b3c4d5e6f7a2b3c4d5e6f7a2b3c4d5e6f7a2b3'
  ssid: something

#
# System configuration
#
system:
  enabled: true
  hostname: offline-lab
  timezone: UTC


#
# SSH Configuration
#
ssh:
  enabled: true
  daemon: dropbear
  directory: /data/config/ssh
  generate_host_keys: true
  keytype: ed25519


#
# Services configuration
#
services:
  enabled: true
  directory: /data/config/services
  services:
  - name: disco
    enabled: true
    sentinel: true
    default_config:
      copy: true
      source: /etc/disco/disco.conf
      destination: /data/config/disco/disco.conf

#
# Users configuration (Done using systemd-sysusers)
#
users:
  enabled: true
  directory: /data/config/users
  users:
  - name: app
    enabled: true
    sudo: false
    home: /data/home/app
    authorized_keys: []

#
# Configs that should be moved into place
#
files:
  enabled: true
  files:
  - source: /boot/firmware/config/disco.conf
    destination: /data/config/disco/disco.conf
    chmod: 640

# render templates to files
templates:
  enabled: true
  templates:
    - source: /boot/firmware/config/disco.conf.tpl
      destination: /data/config/disco/disco.conf
      variables:
        some: blabla
        another: yes
      chmod: 640

shell:
  enabled: true
  directory: /data/bootconf/shell
  # Prepend a directory to PATH for every command (e.g. /usr/lib/framework/bin)
  # Leave empty to inherit PATH from the environment unchanged.
  path: ""
  commands:
    - name: get-process-list
      allow_fail: true
      firstboot: true
      command: |
        bash -c 'ps -ef'
    - name: get-df
      allow_fail: false
      firstboot: false
      command: df /

unitrun:
  # enable / disable
  enabled: true
  # Only run at first boot
  firstboot: false
  # Prepend a directory to PATH in every generated unit (e.g. /usr/lib/framework/bin)
  # Leave empty to omit the Environment=PATH line entirely.
  path: ""
  # Where to save the scripts
  directory: /data/bootconf/scripts
  # unit declarations
  units:
  - name: some-name
    enabled: true
    dependencies:
      - After=multi-user.target
      - Before=shutdown.target
      - Conflicts=shutdown.target
    command: |
      a bunch of commands here
      to run several things
      in a script
      exit 0

























-=------------------------------------------

bootconf:
  enabled: true
  # Status files are written here after each run
  directory: /data/bootconf

wifi:
  # Set enabled: true and fill in ssid/password_hash/country to configure WiFi.
  # password_hash is the PSK hash from wpa_passphrase, not the plaintext password.
  enabled: false
  directory: /data/config/wifi
  ssid: ""
  password_hash: ""
  country: NL

ssh:
  enabled: true
  directory: /data/config/ssh
  keytype: ed25519
  generate_host_keys: true
  daemon: dropbear

system:
  enabled: true
  timezone: Europe/Amsterdam
  hostname: offline-lab

services:
  enabled: true
  directory: /data/config/services
  services:
    - name: disco
      # Set enabled: true to start the disco service discovery daemon.
      enabled: false
      sentinel: true
      default_config:
        copy: true
        source: /etc/disco/config.yaml
        destination: /data/config/disco/config.yaml

sudo:
  enabled: true
  directory: /data/config/sudo

users:
  # Add users here to create them via systemd-sysusers on each boot.
  enabled: false
  directory: /data/config/users
  users: []

files:
  # Copy files from the filesystem into place on /data.
  # Existing files are never overwritten — they get a .new suffix instead.
  enabled: false
  files: []
