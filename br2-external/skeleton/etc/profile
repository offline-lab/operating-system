export PATH="/bin:/sbin:/usr/bin:/usr/sbin:/usr/local/bin:/usr/local/sbin"

if [ "$PS1" ]; then
	if [ "$(id -u)" -eq 0 ]; then
		export PS1='\[\e[1;31m\]\u@\h\[\e[0m\]:\[\e[1;34m\]\w\[\e[0m\]# '
	else
		export PS1='\[\e[1;32m\]\u@\h\[\e[0m\]:\[\e[1;34m\]\w\[\e[0m\]$ '
	fi
fi

export EDITOR='/bin/vi'

for i in /etc/profile.d/*.sh ; do
	if [ -r "$i" ]; then
		. "$i"
	fi
done
unset i
