# Board fragment — merged on top of offlinelab_common_defconfig by build-image.sh.
# Only board-specific settings live here.

# Architecture — Cortex-A72 aarch64 (BCM2711)
BR2_cortex_a72=y

# Kernel — RPi vendor kernel; bcm2711_defconfig is the Pi 4 defconfig
BR2_LINUX_KERNEL_CUSTOM_TARBALL=y
BR2_LINUX_KERNEL_CUSTOM_TARBALL_LOCATION="https://github.com/raspberrypi/linux/archive/refs/tags/rpi-6.12.y_20241206_2.tar.gz"
BR2_LINUX_KERNEL_USE_DEFCONFIG=y
BR2_LINUX_KERNEL_DEFCONFIG="bcm2711"
BR2_LINUX_KERNEL_CONFIG_FRAGMENT_FILES="$(BR2_EXTERNAL_OFFLINELAB_PATH)/boards/common/fragments/linux-kernel.config $(BR2_EXTERNAL_OFFLINELAB_PATH)/boards/rpi/fragments/linux-hardware.config"
BR2_LINUX_KERNEL_DTS_SUPPORT=y
BR2_LINUX_KERNEL_INTREE_DTS_NAME="broadcom/bcm2711-rpi-4-b"

# U-Boot (rpi_4 = Pi 4 specific)
BR2_TARGET_UBOOT_BOARD_DEFCONFIG="rpi_4"
BR2_TARGET_UBOOT_CONFIG_FRAGMENT_FILES="$(BR2_EXTERNAL_OFFLINELAB_PATH)/boards/rpi/rpi4/fragments/uboot-fragment.config"

# RPi firmware — both VARIANT_PI (start.elf) and VARIANT_PI4 (start4.elf) needed
BR2_PACKAGE_RPI_FIRMWARE=y
BR2_PACKAGE_RPI_FIRMWARE_CONFIG_FILE="$(BR2_EXTERNAL_OFFLINELAB_PATH)/boards/rpi/rpi4/config.txt"
BR2_PACKAGE_RPI_FIRMWARE_CMDLINE_FILE="$(BR2_EXTERNAL_OFFLINELAB_PATH)/boards/rpi/rpi4/cmdline.txt"
BR2_PACKAGE_RPI_FIRMWARE_INSTALL_DTB_OVERLAYS=y
BR2_PACKAGE_RPI_FIRMWARE_BOOTCODE_BIN=y
BR2_PACKAGE_RPI_FIRMWARE_VARIANT_PI=y
BR2_PACKAGE_RPI_FIRMWARE_VARIANT_PI4=y

# WiFi + BT firmware (BCM43455)
BR2_PACKAGE_BRCMFMAC_SDIO_FIRMWARE_RPI=y
BR2_PACKAGE_BRCMFMAC_SDIO_FIRMWARE_RPI_WIFI=y
BR2_PACKAGE_BRCMFMAC_SDIO_FIRMWARE_RPI_BT=y

# EEPROM — manages Pi 4 bootloader chip; allows OTA bootloader updates
BR2_PACKAGE_RPI_EEPROM=y

# System
BR2_TARGET_GENERIC_GETTY_PORT="ttyAMA0"

# Post-image scripts
BR2_ROOTFS_POST_SCRIPT_ARGS="$(BR2_EXTERNAL_OFFLINELAB_PATH)/boards/rpi/rpi4 $(BR2_EXTERNAL_OFFLINELAB_PATH)/boards/rpi/hook.sh"
