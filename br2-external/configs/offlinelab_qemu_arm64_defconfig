# Board fragment — merged on top of offlinelab_common_defconfig by build-image.sh.
# Only board-specific settings live here.

# Architecture — Cortex-A53 aarch64, VFPv4 FPU (matches pi-zero-2w for toolchain reuse)
BR2_cortex_a53=y
BR2_ARM_FPU_VFPV4=y

# Kernel — mainline latest; arm64 defconfig + OS fragment + QEMU hardware fragment
BR2_LINUX_KERNEL_LATEST_VERSION=y
BR2_LINUX_KERNEL_USE_CUSTOM_CONFIG=y
BR2_LINUX_KERNEL_CUSTOM_CONFIG_FILE="$(LINUX_DIR)/arch/arm64/configs/defconfig"
BR2_LINUX_KERNEL_CONFIG_FRAGMENT_FILES="$(BR2_EXTERNAL_OFFLINELAB_PATH)/boards/common/fragments/linux-kernel.config $(BR2_EXTERNAL_OFFLINELAB_PATH)/boards/qemu/arm64/fragments/linux-hardware.config"

# U-Boot — qemu_arm64 defconfig; no RPi firmware dependency
BR2_TARGET_UBOOT_BOARD_DEFCONFIG="qemu_arm64"
BR2_TARGET_UBOOT_CONFIG_FRAGMENT_FILES="$(BR2_EXTERNAL_OFFLINELAB_PATH)/boards/qemu/arm64/fragments/uboot-fragment.config"

# System
BR2_TARGET_GENERIC_GETTY_PORT="ttyAMA0"

# Post-image scripts
BR2_ROOTFS_POST_SCRIPT_ARGS="$(BR2_EXTERNAL_OFFLINELAB_PATH)/boards/qemu/arm64 $(BR2_EXTERNAL_OFFLINELAB_PATH)/boards/qemu/hook.sh"

# USB gadget (emulated; wifi/usb-gadget services fail gracefully without hardware)
BR2_PACKAGE_OFFLINELAB_USB_GADGET=y

# Testing — select board-specific bootconf template (no WiFi for QEMU)
BR2_PACKAGE_OFFLINELAB_TESTING_BOARD="qemu-arm64"
