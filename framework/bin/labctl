#!/usr/bin/env bash
# vi: ft=bash
set -euo pipefail

# Dispatcher — no framework needed here, just exec.

cmd="${1:-}"

# No command: hand off to labctl-help for interactive browsing
[[ -z "${cmd}" ]] && exec labctl-help

shift

exec_path="$(command -v "labctl-${cmd}" 2>/dev/null || true)"

if [[ -z "${exec_path}" ]]; then
    printf 'labctl: unknown command "%s"\n\n' "${cmd}" >&2
    exec labctl-help
fi

exec "${exec_path}" "${@}"
