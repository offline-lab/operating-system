#!/usr/bin/env bash
# vi: ft=bash
# shellcheck shell=bash disable=SC1091,SC2312
set -euo pipefail

source framework || exit 1
import interact rauc system

function boxctl_rollback::usage() {
    cat >&2 <<EOF

Usage: boxctl rollback

Roll back to the previously installed RAUC slot.

Finds the inactive rootfs slot, marks it as the boot target, and offers
to reboot. The current slot is not modified — you can roll forward again
by running: boxctl update

EOF
    exit 0
}

function boxctl_rollback::main() {
    [[ "${1:-}" =~ ^(-h|--help)$ ]] && boxctl_rollback::usage

    local active inactive active_version inactive_version

    active="$(rauc::active_slot)" || exit::error "${FUNCNAME[0]}: could not determine active slot — is rauc running?"

    inactive="$(rauc::inactive_slot)" || true

    var::is_empty "${inactive}" && exit::error "${FUNCNAME[0]}: no inactive rootfs slot found. Cannot roll back."

    active_version="$(rauc::slot_version "${active}")"
    inactive_version="$(rauc::slot_version "${inactive}")"

    printf '\n'
    printf '  Current slot  : %s  (version: %s)\n' "${active}" "${active_version}"
    printf '  Rollback to   : %s  (version: %s)\n' "${inactive}" "${inactive_version}"
    printf '\n'

    interact::prompt_bool "Roll back to ${inactive}?" || exit::warn "${FUNCNAME[0]}: Aborted."

    log::info "${FUNCNAME[0]}: marking ${inactive} as next boot slot"
    rauc::mark_active "${inactive}"

    interact::prompt_bool "Reboot now?" && priv::run reboot

    log::info "${FUNCNAME[0]}: rollback staged. Reboot to complete."
}

boxctl_rollback::main "${@}"
