#!/usr/bin/env bash
# vi: ft=bash
# shellcheck shell=bash disable=SC1091,SC2312
set -euo pipefail

source framework || exit 1
import interact config system

SCREEN_BOOTFS_LABEL="bootfs"
SCREEN_BOOTFS_MOUNT="/mnt/bootfs"
SCREEN_CONFIG_TXT="${SCREEN_BOOTFS_MOUNT}/config.txt"

function boxctl_screen::usage() {
    cat >&2 <<EOF

Usage: boxctl screen <subcommand> [args]

Manage HDMI display configuration. Settings are stored in /data/config and
written to /boot/firmware/config.txt on apply. A reboot is required for
changes to take effect.

Subcommands:
  status                     Show stored screen configuration
  rotate <degrees>           Set display rotation: 0, 90, 180, 270
  resolution <group> <mode>  Set HDMI resolution (hdmi_group and hdmi_mode)
  apply                      Write stored settings to /boot/firmware/config.txt

Common HDMI groups and modes:
  Group 1 (CEA/TV):  mode 4 = 720p60,  mode 16 = 1080p60
  Group 2 (DMT/PC):  mode 35 = 1024x768@60, mode 82 = 1920x1080@60

EOF
    exit 0
}

function boxctl_screen::config_txt_set() {
    log::trace "${FUNCNAME[0]}: setting ${1} in config.txt"

    [[ "${#}" -ne 2 ]] && return 2

    local key="${1}" value="${2}"
    shift 2

    if grep -qE "^${key}=" "${SCREEN_CONFIG_TXT}"; then
        sed -i "s|^${key}=.*|${key}=${value}|" "${SCREEN_CONFIG_TXT}"
    else
        printf '%s=%s\n' "${key}" "${value}" >>"${SCREEN_CONFIG_TXT}"
    fi
}

function boxctl_screen::mount_bootfs() {
    log::trace "${FUNCNAME[0]}: mounting ${SCREEN_BOOTFS_LABEL} at ${SCREEN_BOOTFS_MOUNT}"

    mkdir -p "${SCREEN_BOOTFS_MOUNT}"
    priv::run mount -L "${SCREEN_BOOTFS_LABEL}" "${SCREEN_BOOTFS_MOUNT}"
}

function boxctl_screen::umount_bootfs() {
    log::trace "${FUNCNAME[0]}: unmounting ${SCREEN_BOOTFS_MOUNT}"

    priv::run umount "${SCREEN_BOOTFS_MOUNT}"
}

function boxctl_screen::apply() {
    log::trace "${FUNCNAME[0]}: writing screen config to config.txt"

    local rotate hdmi_group hdmi_mode
    rotate="$(config::read screen/rotate)" || rotate=""
    hdmi_group="$(config::read screen/hdmi_group)" || hdmi_group=""
    hdmi_mode="$(config::read screen/hdmi_mode)" || hdmi_mode=""

    if [[ -z "${rotate}${hdmi_group}${hdmi_mode}" ]]; then
        exit::error "${FUNCNAME[0]}: no screen settings stored — nothing to apply"
    fi

    boxctl_screen::mount_bootfs || return 1

    [[ -n "${rotate}" ]] && boxctl_screen::config_txt_set "display_rotate" "${rotate}"
    [[ -n "${hdmi_group}" ]] && boxctl_screen::config_txt_set "hdmi_group" "${hdmi_group}"
    [[ -n "${hdmi_mode}" ]] && boxctl_screen::config_txt_set "hdmi_mode" "${hdmi_mode}"

    boxctl_screen::umount_bootfs

    log::info "${FUNCNAME[0]}: config.txt updated — reboot to apply"
}

function boxctl_screen::main() {
    local subcmd="${1:-}"
    (var::is_empty "${subcmd}" || var::matches "${subcmd}" '^(-h|--help)$') && boxctl_screen::usage
    shift

    case "${subcmd}" in
        status)
            local rotate hdmi_group hdmi_mode
            rotate="$(config::read screen/rotate)" || rotate="not set"
            hdmi_group="$(config::read screen/hdmi_group)" || hdmi_group="not set"
            hdmi_mode="$(config::read screen/hdmi_mode)" || hdmi_mode="not set"
            printf 'rotate:     %s\n' "${rotate}"
            printf 'hdmi_group: %s\n' "${hdmi_group}"
            printf 'hdmi_mode:  %s\n' "${hdmi_mode}"
            ;;
        rotate)
            [[ "${#}" -lt 1 ]] && exit::error "${FUNCNAME[0]}: rotate requires <degrees>"
            local degrees="${1}" rpi_val
            shift
            case "${degrees}" in
                0) rpi_val=0 ;;
                90) rpi_val=1 ;;
                180) rpi_val=2 ;;
                270) rpi_val=3 ;;
                *) exit::error "${FUNCNAME[0]}: invalid rotation '${degrees}' — use 0, 90, 180, or 270" ;;
            esac
            config::write "screen/rotate" "${rpi_val}"
            log::info "${FUNCNAME[0]}: rotation stored as ${degrees}° (display_rotate=${rpi_val})"
            interact::prompt_bool "Apply to config.txt now?" && boxctl_screen::apply
            ;;
        resolution)
            [[ "${#}" -lt 2 ]] && exit::error "${FUNCNAME[0]}: resolution requires <group> <mode>"
            local grp="${1}" mode="${2}"
            shift 2
            config::write "screen/hdmi_group" "${grp}"
            config::write "screen/hdmi_mode" "${mode}"
            log::info "${FUNCNAME[0]}: resolution stored as group=${grp} mode=${mode}"
            interact::prompt_bool "Apply to config.txt now?" && boxctl_screen::apply
            ;;
        apply)
            boxctl_screen::apply
            ;;
        *)
            exit::error "${FUNCNAME[0]}: unknown subcommand: ${subcmd}"
            ;;
    esac
}

boxctl_screen::main "${@}"
