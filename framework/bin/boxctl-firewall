#!/usr/bin/env bash
# vi: ft=bash
# shellcheck shell=bash disable=SC1091,SC2312
set -euo pipefail

source framework || exit 1
import fw

function boxctl_firewall::usage() {
    cat >&2 <<EOF

Usage: boxctl firewall <command>

Manage the nftables firewall.

Commands:
  list      Show the current ruleset (nft list ruleset)
  reload    Reload static rules and per-app fragments
  reset     Flush all rules and remove firewall state
  up        Load rules (same as reload; used after down)
  down      Flush all rules and mark firewall inactive

EOF
    exit 0
}

function boxctl_firewall::main() {
    local cmd="${1:-}"
    [[ "${cmd}" =~ ^(-h|--help)$ ]] && boxctl_firewall::usage
    [[ -z "${cmd}" ]] && boxctl_firewall::usage

    shift

    case "${cmd}" in
        list) fw::list ;;
        reload) fw::reload ;;
        reset) fw::reset ;;
        up) fw::up ;;
        down) fw::down ;;
        *)
            printf 'boxctl firewall: unknown command "%s"\n\n' "${cmd}" >&2
            boxctl_firewall::usage
            ;;
    esac
}

boxctl_firewall::main "${@}"
