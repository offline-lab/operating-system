#!/usr/bin/env bash
# vi: ft=bash
# shellcheck shell=bash disable=SC1091,SC2312
set -euo pipefail

source framework || exit 1
import depends

function labctl_help::usage() {
    cat >&2 <<EOF

Usage: labctl help [command]

Browse available labctl commands.

With fzf:   Interactive list with live usage preview.
Without:    Plain list with usage text.

If a command name is given, show its usage directly:
  labctl help rollback

EOF
    exit 0
}

function labctl_help::list_commands() {
    local bin_dir
    bin_dir="$(dirname "$(command -v labctl 2>/dev/null || echo "/usr/lib/framework/bin/labctl")")"

    find "${bin_dir}" -maxdepth 1 -name 'labctl-*' -type f |
        sed 's|.*/labctl-||' |
        grep -vxE 'help|su' |
        sort
}

function labctl_help::show_one() {
    local cmd="${1}"
    local bin

    bin="$(command -v "labctl-${cmd}" 2>/dev/null || true)"
    var::is_empty "${bin}" && exit::error "${FUNCNAME[0]}: unknown command: ${cmd}"

    "labctl-${cmd}" --help 2>&1 || true
}

function labctl_help::plain() {
    local commands
    commands="$(labctl_help::list_commands)"

    printf '\nAvailable labctl commands:\n\n'

    while IFS= read -r cmd; do
        printf '  labctl %s\n' "${cmd}"
    done <<<"${commands}"

    printf '\nRun '\''labctl <command> --help'\'' for usage details.\n\n'
}

function labctl_help::fzf() {
    local commands selected

    commands="$(labctl_help::list_commands)"

    selected="$(
        printf '%s\n' "${commands}" |
            fzf \
                --prompt='labctl > ' \
                --header='  ↑/↓ to browse   Enter to view full usage   Ctrl+C to exit' \
                --preview='labctl-{} --help 2>&1 || true' \
                --preview-window='right:60%:wrap' \
                --ansi \
                --height='~80%' \
                --border \
                --no-info
    )" || true

    [[ -z "${selected}" ]] && return 0

    printf '\n'
    labctl_help::show_one "${selected}"
}

function labctl_help::main() {
    [[ "${1:-}" =~ ^(-h|--help)$ ]] && labctl_help::usage

    if var::has_value "${1:-}"; then
        labctl_help::show_one "${1}"
        return
    fi

    if depends::check::silent fzf; then
        labctl_help::fzf
    else
        labctl_help::plain
    fi
}

labctl_help::main "${@}"
