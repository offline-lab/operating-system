#!/usr/bin/env bash
# vi: ft=bash
# shellcheck shell=bash disable=SC1091,SC2312
set -euo pipefail

source framework || exit 1
import interact rauc health wifi system

function boxctl_diagnose::usage() {
    cat >&2 <<EOF

Usage: boxctl diagnose [--output <dir>]

Collect diagnostics and write a tarball to /tmp (or <dir>).

Collects:
  - RAUC slot status
  - Failed systemd units + their journals
  - AppArmor denials (dmesg)
  - Last boot log
  - Current boot log
  - WiFi status
  - Disk and memory usage

Options:
  --output <dir>   Write tarball to this directory (default: /tmp)

EOF
    exit 0
}

function boxctl_diagnose::main() {
    [[ "${1:-}" =~ ^(-h|--help)$ ]] && boxctl_diagnose::usage

    local outdir="/tmp"
    if [[ "${1:-}" == "--output" ]]; then
        [[ "${#}" -lt 2 ]] && exit::error "${FUNCNAME[0]}: --output requires a directory argument"
        outdir="${2}"
        shift 2
    fi

    local stamp workdir tarball
    stamp="$(date +%Y%m%d-%H%M%S)"
    workdir="$(mktemp -d)"
    trap 'rm -rf "${workdir}"' EXIT
    tarball="${outdir}/boxctl-diag-${stamp}.tar.gz"

    log::info "${FUNCNAME[0]}: collecting diagnostics"

    rauc::status_json >"${workdir}/rauc-status.json" 2>&1 || true
    health::failed_units >"${workdir}/failed-units.txt" 2>&1 || true
    journalctl -b --no-pager >"${workdir}/journal-current-boot.log" 2>&1 || true
    journalctl -b-1 --no-pager >"${workdir}/journal-last-boot.log" 2>&1 || true
    priv::run dmesg >"${workdir}/dmesg.log" 2>&1 || true
    wifi::print_status >"${workdir}/wifi-status.txt" 2>&1 || true
    df -h >"${workdir}/disk-usage.txt" 2>&1 || true
    free -h >"${workdir}/memory.txt" 2>&1 || true

    while read -r unit; do
        var::is_empty "${unit}" && continue
        journalctl -u "${unit}" -n 200 --no-pager \
            >"${workdir}/unit-${unit}.log" 2>&1 || true
    done < <(health::failed_units)

    tar -czf "${tarball}" -C "$(dirname "${workdir}")" "$(basename "${workdir}")"

    log::info "${FUNCNAME[0]}: diagnostics written to ${tarball}"
}

boxctl_diagnose::main "${@}"
