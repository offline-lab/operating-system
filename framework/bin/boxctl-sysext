#!/usr/bin/env bash
# vi: ft=bash
# shellcheck shell=bash disable=SC1091,SC2312
set -euo pipefail

source framework || exit 1
import sysext

function boxctl_sysext::usage() {
    cat >&2 <<EOF

Usage: boxctl sysext <command>

Manage system extension images in /data/extensions/sysext/.

Commands:
  list      List installed extensions and their merge status
  merge     Merge all extensions into /usr/
  unmerge   Remove merged extensions from /usr/
  refresh   Unmerge then re-merge (picks up new or removed images)
  status    Show current merge state

Extensions are .raw squashfs images stored in /data/extensions/sysext/.
Drop files there and run 'boxctl sysext refresh' to apply them.

EOF
    exit 0
}

function boxctl_sysext::main() {
    local cmd="${1:-}"
    [[ "${cmd}" =~ ^(-h|--help)$ ]] && boxctl_sysext::usage
    [[ -z "${cmd}" ]] && boxctl_sysext::usage

    shift

    case "${cmd}" in
        list) sysext::list ;;
        merge) sysext::merge ;;
        unmerge) sysext::unmerge ;;
        refresh) sysext::refresh ;;
        status) sysext::status ;;
        *)
            printf 'boxctl sysext: unknown command "%s"\n\n' "${cmd}" >&2
            boxctl_sysext::usage
            ;;
    esac
}

boxctl_sysext::main "${@}"
