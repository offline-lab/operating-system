#!/usr/bin/env bash
# vi: ft=bash
# shellcheck shell=bash disable=SC1091,SC2312
set -euo pipefail

source framework || exit 1
import interact wifi system

function boxctl_net::usage() {
    cat >&2 <<EOF

Usage: boxctl net <subcommand> [args]

Subcommands:
  status                Show current WiFi state and IP
  scan                  Scan for available networks
  connect <ssid> <psk>  Connect to a WiFi network

EOF
    exit 0
}

function boxctl_net::main() {
    local subcmd="${1:-}"
    (var::is_empty "${subcmd}" || var::matches "${subcmd}" '^(-h|--help)$') && boxctl_net::usage
    shift

    case "${subcmd}" in
        status) wifi::print_status ;;
        scan) wifi::print_scan ;;
        connect)
            [[ "${#}" -lt 2 ]] && exit::error "${FUNCNAME[0]}: connect requires <ssid> and <psk>"
            wifi::connect "${1}" "${2}"
            ;;
        *)
            exit::error "${FUNCNAME[0]}: unknown subcommand: ${subcmd}"
            ;;
    esac
}

boxctl_net::main "${@}"
