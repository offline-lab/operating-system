#!/usr/bin/env bash
# vi: ft=bash
# shellcheck disable=SC2034,SC2154,SC2155

function framework::usage() {
    cat >/dev/stderr <<EOF

    Offline Lab bash framework

    Source this script to load the framework into your shell, or use it
    as a script interpreter by setting the shebang:

        #!/usr/bin/env framework

    Supported env variables:
      FRAMEWORK_IMPORT       - Set to 1 to force source FRAMEWORK_SCRIPT_PATH
      FRAMEWORK_SCRIPT_NAME  - The (base) name of the executed script
      FRAMEWORK_SCRIPT_PATH  - The full path to the executed script
      FRAMEWORK_BIN_PATH     - The full path to the framework bin/ directory
      FRAMEWORK_LIB_PATH     - The full path to the library/ directory
      FRAMEWORK_LIB_SOURCES  - List of libraries sourced by import

EOF
    exit 0
}

# Set error handling if not used in an interactive or login shell
if ! shopt -q login_shell && [[ -z "${BATS_TEST_FILENAME:-}" ]]; then
    set -o errexit
    set -o errtrace
    set -o nounset
    set -o pipefail
fi

if {
    [[ "${BASH_SOURCE[0]}" == "${0}" ]] && [[ "${#}" -le 1 ]]
} && {
    [[ "${*}" =~ -h ]] || [[ "${*}" =~ --help ]]
}; then
    framework::usage
fi

if [[ "$(basename -- "${0}")" == "framework" ]]; then
    # Used as interpreter: #!/usr/bin/env framework
    declare FRAMEWORK_SCRIPT_PATH="${1:-}"
    declare FRAMEWORK_SCRIPT_NAME="$(basename -- "${FRAMEWORK_SCRIPT_PATH:-}")"
    declare BASH_ARGV0="${1:-}"
    [[ "${#@}" -ne 0 ]] && shift
    declare FRAMEWORK_IMPORT=1

elif [[ "${0}" == "-bash" ]]; then
    # Sourced in a login shell
    declare FRAMEWORK_SCRIPT_PATH=""
    declare FRAMEWORK_SCRIPT_NAME=""
    declare FRAMEWORK_IMPORT=0

else
    # Sourced from another script
    declare FRAMEWORK_SCRIPT_PATH="${0:-}"
    declare FRAMEWORK_SCRIPT_NAME="$(basename -- "${FRAMEWORK_SCRIPT_PATH}")"
    declare FRAMEWORK_IMPORT=0
fi

declare FRAMEWORK_BIN_PATH="$(dirname "${BASH_SOURCE[0]}")"
declare FRAMEWORK_BASE_PATH="$(realpath "${FRAMEWORK_BIN_PATH}/..")"
declare FRAMEWORK_LIB_PATH="${FRAMEWORK_BASE_PATH}/library"
declare FRAMEWORK_TESTS_PATH="${FRAMEWORK_BASE_PATH}/tests"

export \
    FRAMEWORK_BIN_PATH \
    FRAMEWORK_SCRIPT_PATH \
    FRAMEWORK_SCRIPT_NAME \
    FRAMEWORK_BASE_PATH \
    FRAMEWORK_LIB_PATH \
    FRAMEWORK_TESTS_PATH

# shellcheck source=/dev/null
source "${FRAMEWORK_LIB_PATH}/core.sh"

FRAMEWORK_LIB_SOURCES+=("${FRAMEWORK_LIB_PATH}/core.sh")

import "${FRAMEWORK_INIT_MODULES[@]}"

if { [[ -n "${TRACE:-}" ]] && [[ "${TRACE}" == 1 ]]; } || [[ "${-}" =~ x ]]; then
    trap 'debug::handle_error "LINENO" "BASH_LINENO" "${BASH_COMMAND}" "${?}"' ERR
fi

if [[ "${FRAMEWORK_IMPORT:-0}" -eq 1 ]] &&
    [[ -n "${FRAMEWORK_SCRIPT_PATH}" ]] &&
    [[ -e "${FRAMEWORK_SCRIPT_PATH}" ]] &&
    [[ -z "${BATS_TEST_FILENAME:-}" ]] &&
    ! shopt -q login_shell; then

    # shellcheck source=/dev/null
    source "${FRAMEWORK_SCRIPT_PATH}"
fi
