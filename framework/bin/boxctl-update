#!/usr/bin/env bash
# vi: ft=bash
# shellcheck shell=bash disable=SC1091,SC2312
set -euo pipefail

source framework || exit 1
import interact rauc system

function boxctl_update::usage() {
    cat >&2 <<EOF

Usage: boxctl update [<bundle>]

Apply a RAUC bundle. If no path is given, searches /mnt for *.raucb files.
Prompts for confirmation before installing.

Arguments:
  <bundle>   Path to a .raucb file (optional — scans /mnt if omitted)

EOF
    exit 0
}

function boxctl_update::main() {
    [[ "${1:-}" =~ ^(-h|--help)$ ]] && boxctl_update::usage

    local bundle="${1:-}"

    if var::is_empty "${bundle}"; then
        log::info "${FUNCNAME[0]}: scanning for bundles in /mnt"
        local found
        found="$(rauc::find_bundle /mnt)"

        var::is_empty "${found}" && exit::error "${FUNCNAME[0]}: no .raucb bundles found in /mnt"

        local count
        count="$(wc -l <<<"${found}")"
        if [[ "${count}" -gt 1 ]]; then
            printf '%s\n' "${found}" >&2
            exit::error "${FUNCNAME[0]}: multiple bundles found — specify one explicitly"
        fi

        bundle="${found}"
    fi

    local version compatible
    version="$(rauc::bundle_version "${bundle}")"
    compatible="$(rauc::bundle_compatible "${bundle}")"

    printf '\n  Bundle    : %s\n' "$(basename "${bundle}")"
    printf '  Version   : %s\n' "${version}"
    printf '  Compatible: %s\n\n' "${compatible}"

    interact::prompt_bool "Install this bundle?" || exit::warn "${FUNCNAME[0]}: Aborted."

    log::info "${FUNCNAME[0]}: installing ${bundle}"
    rauc::install "${bundle}"
    log::info "${FUNCNAME[0]}: install complete"

    interact::prompt_bool "Reboot now?" && priv::run reboot
}

boxctl_update::main "${@}"
