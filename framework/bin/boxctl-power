#!/usr/bin/env bash
# vi: ft=bash
# shellcheck shell=bash disable=SC1091,SC2312
set -euo pipefail

source framework || exit 1
import config power system

function boxctl_power::usage() {
    cat >&2 <<EOF

Usage: boxctl power [<subcommand>]

Manage runtime power profile (cpufreq governor + USB autosuspend).

Subcommands:
  get           Show the active profile (default)
  set <name>    Persist and apply a profile
  apply         Re-apply the persisted profile — called at boot by power-profile.service
  list          List available profiles

Profiles:
  performance   CPU governor: performance, USB autosuspend: disabled
  balanced      CPU governor: schedutil,   USB autosuspend: 2000ms  (default)
  saver         CPU governor: powersave,   USB autosuspend: 500ms

EOF
    exit 0
}

function boxctl_power::main() {
    local subcmd="${1:-get}"
    (var::matches "${subcmd}" '^(-h|--help)$') && boxctl_power::usage
    shift || true

    case "${subcmd}" in
        get)
            power::get_profile
            ;;
        set)
            [[ "${#}" -lt 1 ]] && exit::error "${FUNCNAME[0]}: set requires <profile>"
            power::set_profile "${1}" || exit::error "${FUNCNAME[0]}: failed to set profile: ${1}"
            ;;
        apply)
            local profile
            profile="$(power::get_profile)"
            power::apply_profile "${profile}" || exit::error "${FUNCNAME[0]}: failed to apply profile: ${profile}"
            ;;
        list)
            power::list_profiles
            ;;
        *)
            exit::error "${FUNCNAME[0]}: unknown subcommand: ${subcmd}"
            ;;
    esac
}

boxctl_power::main "${@}"
