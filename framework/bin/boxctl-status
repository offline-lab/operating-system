#!/usr/bin/env bash
# vi: ft=bash
# shellcheck shell=bash disable=SC1091,SC2312
set -euo pipefail

source framework || exit 1
import interact rauc health system

function boxctl_status::usage() {
    cat >&2 <<EOF

Usage: boxctl status

Show system health: RAUC slot info, AppArmor, dm-verity, failed units,
disk and memory usage.

EOF
    exit 0
}

function boxctl_status::main() {
    [[ "${1:-}" =~ ^(-h|--help)$ ]] && boxctl_status::usage

    printf 'RAUC Slots\n'
    rauc::print_slots

    printf 'System Health\n'
    health::print_health
}

boxctl_status::main "${@}"
