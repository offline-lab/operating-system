#!/usr/bin/env bash
# vi: ft=bash
# shellcheck shell=bash disable=SC1091
set -euo pipefail

source framework || exit 1

## Print help output
function tools::usage() {
    cat <<EOF

    Browse utils in ~/bin/

    This script prints a nice overview of all ~/bin scripts
    using fzf with preview.

    ${FRAMEWORK_SCRIPT_NAME:-${0}} [-h|--help]

    Arguments:
      -d, --directory - The directory to list tools for
      -h, --help      - Show this menu

    Example:
      ${FRAMEWORK_SCRIPT_NAME:-${0}}

EOF

    exit 0
}

function tools::main() {
    if ! depends::check_list fzf find; then
        exit::error "${FUNCNAME[0]}: This tool depends on fzf and find"
    fi

    local -a directories=()

    while [[ "${1:-}" != "" ]]; do
        case "${1}" in
        -h | --help)
            tools::usage
            ;;

        -d | --dir | --directory)
            directories+=("${2:-}")
            shift
            ;;

        *)
            tools::usage
            ;;
        esac

        shift || true
    done

    if [[ "${#directories[@]}" -lt 1 ]]; then
        directories+=(
            "${HOME}/bin/"
            "/usr/lib/framework"
        )
    fi

    for directory in "${directories[@]}"; do
        if ! directory="$(realpath -q "${directory}")" || ! fs::is_dir "${directory}"; then
            exit::error "${FUNCNAME[0]}: Directory ${directory} not found!"
        fi
    done

    exec find "${directories[@]}" \
        -follow \
        -maxdepth 1 \
        -not -name '*.swp' \
        -type f |
        sort |
        fzf --preview "command {} -h" >/dev/null
}

tools::main "${@}"
